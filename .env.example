# ============================================================
# Sudarshan (Shastra) — Environment Variables
# ============================================================
# This file documents all required env vars for the three-layer
# architecture: Convex Cloud + Shastra Compute + Next.js Frontend
#
# Never commit .env files. Set values in the appropriate dashboard.
# ============================================================

# ---- Convex Cloud ----
# Set via: npx convex env set <KEY> <VALUE>
# Or in the Convex dashboard: https://dashboard.convex.dev

# URL of the Shastra Compute API (Cloudflare Containers)
SHASTRA_COMPUTE_URL=https://api.forsee.life

# Shared secret for X-API-Key auth between Convex and Shastra Compute
# Generate: openssl rand -hex 32
SHASTRA_COMPUTE_API_KEY=

# HMAC signing key for streaming tokens (must match on both sides)
# Generate: openssl rand -hex 32
STREAM_TOKEN_SECRET=

# Google Gemini API key (for LLM-powered readings)
GEMINI_API_KEY=

# Geocoding API key (for birthplace → lat/lng resolution)
GEOCODING_API_KEY=

# ---- Convex Auth ----
# Google OAuth (from Google Cloud Console → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (for email magic links) — from https://resend.com/api-keys
AUTH_RESEND_KEY=

# ---- Polar.sh (set in Convex env vars) ----
# Org token from Polar dashboard → Settings → API
POLAR_ORGANIZATION_TOKEN=

# Webhook secret from Polar dashboard → Webhooks
POLAR_WEBHOOK_SECRET=

# ---- Shastra Compute (Cloudflare Workers) ----
# Set in Cloudflare dashboard → Worker → Settings → Variables
# API_KEY=<same as SHASTRA_COMPUTE_API_KEY>
# STREAM_TOKEN_SECRET=<same as STREAM_TOKEN_SECRET>
# GEMINI_API_KEY=<same as GEMINI_API_KEY>
# GEOCODING_API_KEY=<same as GEOCODING_API_KEY>

# ---- Frontend (Cloudflare Pages) ----
# Set in Cloudflare Pages → Settings → Environment Variables
# NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud
